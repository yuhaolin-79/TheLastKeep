	-$(DEL_FILE) release\Castle.o release\Mainwindow.o release\bullet.o release\card.o release\cardmanager.o release\enemy.o release\gamecontroller.o release\gamescene.o release\main.o release\tower.o release\qrc_resource.o release\moc_Mainwindow.o release\moc_card.o release\moc_cardmanager.o release\moc_gamecontroller.o release\moc_gamescene.o

distclean: clean 
	-$(DEL_FILE) .qmake.stash
	-$(DEL_FILE) $(DESTDIR_TARGET)
	-$(DEL_FILE) Makefile.Release

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

